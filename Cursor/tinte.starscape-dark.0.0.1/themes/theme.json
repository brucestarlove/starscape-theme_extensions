    "activityBarBadge.foreground": "#0a1121"
  },
  "tokenColors": [
    {
      "name": "plain",
      "scope": [
        "source",
        "support.type.property-name.css"
      ],
      "settings": {
        "foreground": "#e5edff"
      }
    },
    {
      "name": "punctuation",
      "scope": [
        "punctuation",
        "punctuation.terminator",
        "punctuation.definition.tag",
        "punctuation.separator",
        "punctuation.definition.string",
        "punctuation.section.block"
      ],
      "settings": {
        "foreground": "#a1a6c5"
      }
    },
    {
      "name": "classes",
      "scope": [
        "entity.name.type.class"
      ],
      "settings": {
        "foreground": "#06b6d4"
      }
    },
    {
      "name": "interfaces",
      "scope": [
        "entity.name.type.interface",
        "entity.name.type"
      ],
      "settings": {
        "foreground": "#06b6d4"
      }
    },
    {
      "name": "structs",
      "scope": [
        "entity.name.type.struct"
      ],
      "settings": {
        "foreground": "#06b6d4"
      }
    },
    {
      "name": "enums",
      "scope": [
        "entity.name.type.enum"
      ],
      "settings": {
        "foreground": "#06b6d4"
      }
    },
    {
      "name": "types",
      "scope": [
        "support.type"
      ],
      "settings": {
        "foreground": "#a855f7"
      }
    },
    {
      "name": "typeParameters",
      "scope": [
        "variable.type.parameter",
        "variable.parameter.type"
      ],
      "settings": {
        "foreground": "#06b6d4"
      }
    },
    {
      "name": "functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#06b6d4"
      }
    },
    {
      "name": "methods",
      "scope": [
        "entity.name.function.method",
        "meta.function.method"
      ],
      "settings": {
        "foreground": "#a855f7"
      }
    },
    {
      "name": "calls",
      "scope": [
        "variable.function"
      ],
      "settings": {
        "foreground": "#e5edff"
      }
    },
    {
      "name": "variables",
      "scope": [
        "variable",
        "meta.variable",
        "variable.other.object.property",
        "variable.other.readwrite.alias"
      ],
      "settings": {
        "foreground": "#e5edff"
      }
    },
    {
      "name": "variablesOther",
      "scope": [
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#e5edff"
      }
    },
    {
      "name": "globalVariables",
      "scope": [
        "variable.other.global",
        "variable.language.this"
      ],
      "settings": {
        "foreground": "#eab308"
      }
    },
    {
      "name": "localVariables",
      "scope": [
        "variable.other.local"
      ],
      "settings": {
        "foreground": "#e5edff"
      }
    },
    {
      "name": "parameters",
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#e5edff"
      }
    },
    {
      "name": "properties",
      "scope": [
        "variable.other.property",
        "meta.property"
      ],
      "settings": {
        "foreground": "#e5edff"
      }
    },
    {
      "name": "keys",
      "scope": [
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#e5edff"
      }
    },
    {
      "name": "keywords",
      "scope": [
        "keyword"
      ],
      "settings": {
        "foreground": "#a855f7"
      }
    },
    {
      "name": "keywordsControl",
      "scope": [
        "keyword.control.import",
        "keyword.control.from",
        "keyword.import"
      ],
      "settings": {
        "foreground": "#a855f7"
      }
    },
    {
      "name": "storageModifiers",
      "scope": [
        "storage.modifier",
        "keyword.modifier",
        "storage.type"
      ],
      "settings": {
        "foreground": "#a855f7"
      }
    },
    {
      "name": "operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#a855f7"
      }
    },
    {
      "name": "strings",
      "scope": [
        "string",
        "string.other.link",
        "markup.inline.raw.string.markdown"
      ],
      "settings": {
        "foreground": "#eab308"
      }
    },
    {
      "name": "stringEscapeSequences",
      "scope": [
        "constant.character.escape",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#e5edff"
      }
    },
    {
      "name": "numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#ec4899"
      }
    },
    {
      "name": "booleans",
      "scope": [
        "constant.language.boolean",
        "constant.language.json"
      ],
      "settings": {
        "foreground": "#ec4899"
      }
    },
    {
      "name": "constants",
      "scope": [
        "variable.other.constant",
        "variable.readonly"
      ],
      "settings": {
        "foreground": "#e5edff"
      }
    },
    {
      "name": "comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#70799b"
      }
    },
    {
      "name": "docComments",
      "scope": [
        "comment.documentation",
        "comment.line.documentation"
      ],
      "settings": {
        "foreground": "#70799b"
      }
    },
    {
      "name": "tags",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#a855f7"
      }
    },
    {
      "name": "jsxTags",
      "scope": [
        "support.class.component"
      ],
      "settings": {
        "foreground": "#a855f7"
      }
    },
    {
      "name": "attributes",
      "scope": [
        "entity.other.attribute-name",
        "meta.attribute"
      ],
      "settings": {
        "foreground": "#06b6d4"
      }
    },
    {
      "name": "urls",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#a855f7"
      }
    },
    {
      "name": "namespaces",
      "scope": [
        "entity.name.namespace",
        "storage.modifier.namespace",
        "markup.bold.markdown"
      ],
      "settings": {
        "foreground": "#06b6d4"
      }
    },
    {
      "name": "modules",
      "scope": [
        "entity.name.module",
        "storage.modifier.module"
      ],
      "settings": {
        "foreground": "#a855f7"
      }
    },
    {
      "name": "macros",
      "scope": [
        "entity.name.function.preprocessor",
        "meta.preprocessor"
      ],
      "settings": {
        "foreground": "#a855f7"
      }
    },
    {
      "name": "preprocessor",
      "scope": [
        "meta.preprocessor"
      ],
      "settings": {
        "foreground": "#eab308"
      }
    },
    {
      "name": "exceptions",
      "scope": [
        "keyword.control.exception",
        "keyword.control.trycatch"
      ],
      "settings": {
        "foreground": "#a855f7"
      }
    },
    {
      "name": "decorators",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#06b6d4"
      }
    },
    {
      "name": "labels",
      "scope": [
        "entity.name.label",
        "punctuation.definition.label"
      ],
      "settings": {
        "foreground": "#eab308"
      }
    }
  ]
}
