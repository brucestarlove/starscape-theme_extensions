{
  "name": "Starscape Light",
  "displayName": "Starscape Light",
  "type": "light",
  "colors": {
    "editor.background": "#f5ecd6",
    "editor.foreground": "#2b2415",
    "editor.hoverHighlightBackground": "#e3d4ad66",
    "editor.lineHighlightBackground": "#efe4c8",
    "editor.selectionBackground": "#d4c19477",
    "editor.selectionHighlightBackground": "#d4c19411",
    "editor.wordHighlightBackground": "#e3d4ad11",
    "editor.wordHighlightStrongBackground": "#e8d9b422",
    "editor.findMatchBackground": "#4f704866",
    "editor.findMatchHighlightBackground": "#4f704855",
    "editor.findRangeHighlightBackground": "#efe4c8cc",
    "editor.inactiveSelectionBackground": "#d4c19466",
    "editor.lineHighlightBorder": "#e8d9b4",
    "editor.rangeHighlightBackground": "#efe4c844",
    "editorWhitespace.foreground": "#d4c194",
    "editorIndentGuide.background1": "#d4c194",
    "editorHoverWidget.background": "#efe4c8",
    "editorLineNumber.activeForeground": "#2b2415",
    "editorLineNumber.foreground": "#9c8a64",
    "editorGutter.background": "#f5ecd6",
    "editorGutter.modifiedBackground": "#a0563a",
    "editorGutter.addedBackground": "#4f7048",
    "editorGutter.deletedBackground": "#8b3a3a",
    "editorBracketMatch.background": "#e8d9b4",
    "editorBracketMatch.border": "#d4c194",
    "editorGroupHeader.tabsBackground": "#f5ecd6",
    "editorGroup.border": "#d4c194",
    "tab.activeBackground": "#f5ecd6",
    "tab.inactiveBackground": "#efe4c8",
    "tab.inactiveForeground": "#463e2f",
    "tab.activeForeground": "#2b2415",
    "tab.hoverBackground": "#e3d4ad",
    "tab.unfocusedHoverBackground": "#e3d4ad",
    "tab.border": "#d4c194",
    "tab.activeModifiedBorder": "#a0563a",
    "tab.inactiveModifiedBorder": "#b8893d",
    "editorWidget.background": "#efe4c8",
    "editorWidget.border": "#d4c194",
    "editorSuggestWidget.background": "#f5ecd6",
    "editorSuggestWidget.border": "#d4c194",
    "editorSuggestWidget.foreground": "#2b2415",
    "editorSuggestWidget.highlightForeground": "#4f7048",
    "editorSuggestWidget.selectedBackground": "#e3d4ad",
    "panel.background": "#f5ecd6",
    "panel.border": "#d4c194",
    "panelTitle.activeBorder": "#9c8a64",
    "panelTitle.activeForeground": "#2b2415",
    "panelTitle.inactiveForeground": "#463e2f",
    "statusBar.background": "#f5ecd6",
    "statusBar.foreground": "#2b2415",
    "statusBar.border": "#d4c194",
    "statusBar.debuggingBackground": "#587a64",
    "statusBar.debuggingForeground": "#f5ecd6",
    "titleBar.activeBackground": "#f5ecd6",
    "titleBar.activeForeground": "#2b2415",
    "titleBar.inactiveBackground": "#efe4c8",
    "titleBar.inactiveForeground": "#463e2f",
    "titleBar.border": "#d4c194",
    "menu.foreground": "#2b2415",
    "menu.background": "#f5ecd6",
    "menu.selectionForeground": "#2b2415",
    "menu.selectionBackground": "#e3d4ad",
    "menu.border": "#d4c194",
    "terminal.foreground": "#2b2415",
    "terminal.background": "#f5ecd6",
    "terminalCursor.foreground": "#2b2415",
    "terminalCursor.background": "#f5ecd6",
    "terminal.ansiRed": "#8b3a3a",
    "terminal.ansiGreen": "#4f7048",
    "terminal.ansiYellow": "#b8893d",
    "terminal.ansiBlue": "#587a64",
    "terminal.ansiMagenta": "#6b4a8a",
    "terminal.ansiCyan": "#5e7d70",
    "activityBar.background": "#f5ecd6",
    "activityBar.foreground": "#2b2415",
    "activityBar.inactiveForeground": "#463e2f",
    "activityBar.activeBorder": "#2b2415",
    "activityBar.border": "#d4c194",
    "sideBar.background": "#f5ecd6",
    "sideBar.foreground": "#2b2415",
    "sideBar.border": "#d4c194",
    "sideBarTitle.foreground": "#2b2415",
    "sideBarSectionHeader.background": "#efe4c8",
    "sideBarSectionHeader.foreground": "#2b2415",
    "sideBarSectionHeader.border": "#d4c194",
    "list.foreground": "#2b2415",
    "list.inactiveSelectionBackground": "#d4c194",
    "list.activeSelectionBackground": "#e3d4ad",
    "list.inactiveSelectionForeground": "#2b2415",
    "list.activeSelectionForeground": "#2b2415",
    "list.focusOutline": "#4f7048",
    "list.hoverForeground": "#2b2415",
    "list.hoverBackground": "#e3d4ad",
    "input.background": "#efe4c8",
    "input.foreground": "#2b2415",
    "input.border": "#d4c194",
    "input.placeholderForeground": "#7a6c4f",
    "dropdown.background": "#efe4c8",
    "dropdown.foreground": "#2b2415",
    "dropdown.border": "#d4c194",
    "dropdown.listBackground": "#f5ecd6",
    "badge.background": "#4f7048",
    "activityBarBadge.background": "#4f7048",
    "button.background": "#4f7048",
    "button.foreground": "#f5ecd6",
    "badge.foreground": "#f5ecd6",
    "activityBarBadge.foreground": "#f5ecd6"
  },
  "tokenColors": [
    {
      "name": "plain",
      "scope": [
        "source",
        "support.type.property-name.css"
      ],
      "settings": {
        "foreground": "#2b2415"
      }
    },
    {
      "name": "punctuation",
      "scope": [
        "punctuation",
        "punctuation.terminator",
        "punctuation.definition.tag",
        "punctuation.separator",
        "punctuation.definition.string",
        "punctuation.section.block"
      ],
      "settings": {
        "foreground": "#7a6c4f"
      }
    },
    {
      "name": "classes",
      "scope": [
        "entity.name.type.class"
      ],
      "settings": {
        "foreground": "#a0563a"
      }
    },
    {
      "name": "interfaces",
      "scope": [
        "entity.name.type.interface",
        "entity.name.type"
      ],
      "settings": {
        "foreground": "#a0563a"
      }
    },
    {
      "name": "structs",
      "scope": [
        "entity.name.type.struct"
      ],
      "settings": {
        "foreground": "#a0563a"
      }
    },
    {
      "name": "enums",
      "scope": [
        "entity.name.type.enum"
      ],
      "settings": {
        "foreground": "#a0563a"
      }
    },
    {
      "name": "types",
      "scope": [
        "support.type"
      ],
      "settings": {
        "foreground": "#a0563a"
      }
    },
    {
      "name": "typeParameters",
      "scope": [
        "variable.type.parameter",
        "variable.parameter.type"
      ],
      "settings": {
        "foreground": "#a0563a"
      }
    },
    {
      "name": "functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#4f7048"
      }
    },
    {
      "name": "methods",
      "scope": [
        "entity.name.function.method",
        "meta.function.method"
      ],
      "settings": {
        "foreground": "#4f7048"
      }
    },
    {
      "name": "calls",
      "scope": [
        "variable.function"
      ],
      "settings": {
        "foreground": "#2b2415"
      }
    },
    {
      "name": "variables",
      "scope": [
        "variable",
        "meta.variable",
        "variable.other.object.property",
        "variable.other.readwrite.alias"
      ],
      "settings": {
        "foreground": "#2b2415"
      }
    },
    {
      "name": "variablesOther",
      "scope": [
        "variable.other.object"
      ],
      "settings": {
        "foreground": "#2b2415"
      }
    },
    {
      "name": "globalVariables",
      "scope": [
        "variable.other.global",
        "variable.language.this"
      ],
      "settings": {
        "foreground": "#b8893d"
      }
    },
    {
      "name": "localVariables",
      "scope": [
        "variable.other.local"
      ],
      "settings": {
        "foreground": "#2b2415"
      }
    },
    {
      "name": "parameters",
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#2b2415"
      }
    },
    {
      "name": "properties",
      "scope": [
        "variable.other.property",
        "meta.property"
      ],
      "settings": {
        "foreground": "#2b2415"
      }
    },
    {
      "name": "keys",
      "scope": [
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#2b2415"
      }
    },
    {
      "name": "keywords",
      "scope": [
        "keyword"
      ],
      "settings": {
        "foreground": "#4f7048"
      }
    },
    {
      "name": "keywordsControl",
      "scope": [
        "keyword.control.import",
        "keyword.control.from",
        "keyword.import"
      ],
      "settings": {
        "foreground": "#4f7048"
      }
    },
    {
      "name": "storageModifiers",
      "scope": [
        "storage.modifier",
        "keyword.modifier",
        "storage.type"
      ],
      "settings": {
        "foreground": "#4f7048"
      }
    },
    {
      "name": "operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#4a3820"
      }
    },
    {
      "name": "strings",
      "scope": [
        "string",
        "string.other.link",
        "markup.inline.raw.string.markdown"
      ],
      "settings": {
        "foreground": "#b8893d"
      }
    },
    {
      "name": "stringEscapeSequences",
      "scope": [
        "constant.character.escape",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#2b2415"
      }
    },
    {
      "name": "numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#8b3a3a"
      }
    },
    {
      "name": "booleans",
      "scope": [
        "constant.language.boolean",
        "constant.language.json"
      ],
      "settings": {
        "foreground": "#8b3a3a"
      }
    },
    {
      "name": "constants",
      "scope": [
        "variable.other.constant",
        "variable.readonly"
      ],
      "settings": {
        "foreground": "#2b2415"
      }
    },
    {
      "name": "comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7a6c4f",
        "fontStyle": "italic"
      }
    },
    {
      "name": "docComments",
      "scope": [
        "comment.documentation",
        "comment.line.documentation"
      ],
      "settings": {
        "foreground": "#7a6c4f",
        "fontStyle": "italic"
      }
    },
    {
      "name": "tags",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#4f7048"
      }
    },
    {
      "name": "jsxTags",
      "scope": [
        "support.class.component"
      ],
      "settings": {
        "foreground": "#4f7048"
      }
    },
    {
      "name": "attributes",
      "scope": [
        "entity.other.attribute-name",
        "meta.attribute"
      ],
      "settings": {
        "foreground": "#6b4a8a"
      }
    },
    {
      "name": "urls",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#a0563a"
      }
    },
    {
      "name": "namespaces",
      "scope": [
        "entity.name.namespace",
        "storage.modifier.namespace",
        "markup.bold.markdown"
      ],
      "settings": {
        "foreground": "#6b4a8a"
      }
    },
    {
      "name": "modules",
      "scope": [
        "entity.name.module",
        "storage.modifier.module"
      ],
      "settings": {
        "foreground": "#4f7048"
      }
    },
    {
      "name": "macros",
      "scope": [
        "entity.name.function.preprocessor",
        "meta.preprocessor"
      ],
      "settings": {
        "foreground": "#4a3820"
      }
    },
    {
      "name": "preprocessor",
      "scope": [
        "meta.preprocessor"
      ],
      "settings": {
        "foreground": "#4a3820"
      }
    },
    {
      "name": "exceptions",
      "scope": [
        "keyword.control.exception",
        "keyword.control.trycatch"
      ],
      "settings": {
        "foreground": "#4f7048"
      }
    },
    {
      "name": "decorators",
      "scope": [
        "meta.decorator",
        "punctuation.decorator",
        "entity.name.function.decorator"
      ],
      "settings": {
        "foreground": "#6b4a8a"
      }
    },
    {
      "name": "labels",
      "scope": [
        "entity.name.label",
        "punctuation.definition.label"
      ],
      "settings": {
        "foreground": "#b8893d"
      }
    }
  ]
}
