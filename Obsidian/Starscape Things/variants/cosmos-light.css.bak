/* ============================================================
   Starscape palette overrides for the Things theme.
   Appended after upstream/theme.css by build.sh — same selectors
   as upstream so the cascade picks these up.

   Palette source: starscape_dark.json (Zed). Light palette is
   designed for true white backgrounds (Zed's light variant is a
   lighter-dark, not suitable for Obsidian theme-light).
   ============================================================ */

/* Shared accent palette — Things uses these for h-colors, strong, em, quote, etc. */
body {
  /* Accent hue tuned to Starscape purple #a855f7 ≈ hsl(271, 91%, 65%) */
  --accent-h: 271;
  --accent-s: 91%;
  --accent-d: 65%; /* dark mode */
  --accent-l: 55%; /* light mode (darkened for contrast on white) */

  /* Things' named colors, remapped to Starscape */
  --blue: #06b6d4;   /* cyan */
  --pink: #ec4899;
  --green: #eab308;  /* gold — Starscape uses gold where Things uses green */
  --yellow: #eab308;
  --orange: #ec4899; /* no orange in Starscape; reuse pink */
  --red: #ec4899;
  --purple: #a855f7;

  /* Heading colors — keep h1/h2 as text-normal (Things default), restyle the rest */
  --h3-color: #06b6d4; /* cyan */
  --h4-color: #a855f7; /* purple */
  --h5-color: #eab308; /* gold */
  --h6-color: var(--text-muted);

  --strong-color: #06b6d4; /* cyan — bold */
  --em-color: #a855f7;     /* purple — italic */
  --quote-color: #eab308;

  /* Tag pills — purple on dark, light purple on light */
  --tag-background-color-l: #ede0fc;
  --tag-font-color-l: #6b21a8;
  --tag-background-color-d: #3b1d63;
  --tag-font-color-d: #e9d5ff;

  /* Code block backgrounds */
  --code-background-l: #eef0f6;
  --code-background-d: #10182e;
  --code-block-background-l: #f4f5fa;
  --code-block-background-d: #0d142a;
}

/* ===================== Dark — Starscape ===================== */
.theme-dark,
body.theme-dark.is-mobile {
  --color-red-rgb: 236, 72, 153;
  --color-red: #ec4899;
  --color-green-rgb: 234, 179, 8;
  --color-green: #eab308;
  --color-orange: #ec4899;
  --color-yellow: #eab308;
  --color-cyan: #06b6d4;
  --color-blue: #06b6d4;
  --color-purple: #a855f7;
  --color-pink: #ec4899;

  /* Surfaces — deep navy ladder from starscape_dark.json */
  --color-base-00: #0a1121; /* main editor */
  --color-base-05: #0d142a;
  --color-base-10: #10182e; /* code blocks, surfaces */
  --color-base-20: #0a1121; /* unfocused nav */
  --color-base-25: #1a2240;
  --color-base-30: #232946; /* dividers */
  --color-base-35: #2d3459;
  --color-base-40: #373d5b;
  --color-base-50: #70799b; /* faint text */
  --color-base-60: #8a92b3;
  --color-base-70: #a1a6c5; /* muted text */
  --color-base-100: #e5edff; /* normal text */

  --titlebar-background: #0a1121;
  --titlebar-background-focused: #10182e;

  /* Highlights — subtle gold wash, pink active */
  --text-highlight-bg-d: rgba(234, 179, 8, 0.28);
  --text-highlight-bg: var(--text-highlight-bg-d);
  --text-highlight-bg-active: rgba(236, 72, 153, 0.32);

  /* Atom syntax — remap to Starscape */
  --atom-gray-1: #70799b;
  --atom-gray-2: #a1a6c5;
  --atom-red: #ec4899;
  --atom-orange: #ec4899;
  --atom-green: #eab308;
  --atom-aqua: #06b6d4;
  --atom-purple: #a855f7;
  --atom-blue: #06b6d4;
  --atom-yellow: #eab308;
}

/* ===================== Light — Starscape ===================== */
/* Cool off-white backgrounds, deep navy text, accents darkened for AA contrast. */
.theme-light,
body.theme-light.is-mobile {
  --color-red-rgb: 219, 39, 119;
  --color-red: #db2777;
  --color-green-rgb: 161, 98, 7;
  --color-green: #a16207;
  --color-orange: #db2777;
  --color-yellow: #a16207;
  --color-cyan: #0891b2;
  --color-blue: #0891b2;
  --color-purple: #9333ea;
  --color-pink: #db2777;

  --color-base-00: #fafbfd; /* main editor */
  --color-base-05: #f4f6fb;
  --color-base-10: #eef0f6; /* code blocks */
  --color-base-20: #eef0f6;
  --color-base-25: #e3e7f0;
  --color-base-30: #d8dce8; /* dividers */
  --color-base-35: #c4c9d8;
  --color-base-40: #a8aec3;
  --color-base-50: #8a90ab;
  --color-base-60: #6b7290;
  --color-base-70: #4a5070;
  --color-base-100: #0a1121; /* normal text */

  --titlebar-background: #eef0f6;
  --titlebar-background-focused: #e3e7f0;

  --text-highlight-bg-l: rgba(161, 98, 7, 0.22);
  --text-highlight-bg: var(--text-highlight-bg-l);
  --text-highlight-bg-active: rgba(219, 39, 119, 0.28);

  /* Atom syntax — light variants of the accents */
  --atom-gray-1: #4a5070;
  --atom-gray-2: #4a5070;
  --atom-red: #db2777;
  --atom-orange: #b45309;
  --atom-green: #a16207;
  --atom-aqua: #0891b2;
  --atom-purple: #9333ea;
  --atom-blue: #0891b2;
  --atom-yellow: #a16207;
}

/* Light-mode heading/strong/em recolors — accent-l (darkened) versions */
.theme-light {
  --h3-color: #0891b2; /* cyan */
  --h4-color: #9333ea; /* purple */
  --h5-color: #a16207;
  --strong-color: #0891b2; /* cyan — bold */
  --em-color: #9333ea;     /* purple — italic */
  --quote-color: #a16207;
}

/* ============================================================
   Orbit board background — ported from minimal-agent-board
   Layered stack: two radial accent washes + diagonal surface
   gradient + 11/12px gridpaper from repeating-linear-gradients.
   Applied to the note view surface only; chrome stays solid.
   ============================================================ */

.theme-dark {
  --orbit-surface:   rgba(15, 20, 35, 0.95);
  --orbit-surface-2: rgba(10, 14, 28, 0.98);
  --orbit-accent:    rgba(168, 134, 247, 0.10); /* purple wash */
  --orbit-accent-2:  rgba(6, 182, 212, 0.08);   /* cyan wash */
}

.theme-light {
  --orbit-surface:   rgba(250, 251, 253, 1);
  --orbit-surface-2: rgba(238, 240, 246, 1);
  --orbit-grid:      rgba(29, 37, 40, 0.08);
  --orbit-accent:    rgba(147, 51, 234, 0.18);
  --orbit-accent-2:  rgba(8, 145, 178, 0.14);
}

/* Dark — Orbit washes + surface, NO grid (stars carry the texture). */
.theme-dark .markdown-source-view.mod-cm6 .cm-editor,
.theme-dark .markdown-source-view.mod-cm6 .cm-scroller,
.theme-dark .markdown-preview-view,
.theme-dark .workspace-leaf-content[data-type="markdown"] .view-content {
  background:
    radial-gradient(ellipse 80% 50% at 50% 0%, var(--orbit-accent), transparent 55%),
    radial-gradient(circle at 100% 100%, var(--orbit-accent-2), transparent 45%),
    linear-gradient(165deg, var(--orbit-surface) 0%, var(--orbit-surface-2) 100%);
  background-attachment: local;
}

/* Light — grid above surface so it's actually visible. 12×12 squares;
   we don't try to align rules to text baselines (CSS gradients can't
   respond to per-element line-heights, so the result looks like graph
   paper, not ruled paper). */
.theme-light .markdown-source-view.mod-cm6 .cm-editor,
.theme-light .markdown-source-view.mod-cm6 .cm-scroller,
.theme-light .markdown-preview-view,
.theme-light .workspace-leaf-content[data-type="markdown"] .view-content {
  background:
    repeating-linear-gradient(0deg,  transparent, transparent 11px, var(--orbit-grid) 11px, var(--orbit-grid) 12px),
    repeating-linear-gradient(90deg, transparent, transparent 11px, var(--orbit-grid) 11px, var(--orbit-grid) 12px),
    radial-gradient(ellipse 80% 50% at 50% 0%, var(--orbit-accent), transparent 55%),
    radial-gradient(circle at 100% 100%, var(--orbit-accent-2), transparent 45%),
    linear-gradient(165deg, var(--orbit-surface) 0%, var(--orbit-surface-2) 100%);
  background-attachment: local;
}

/* Things paints opaque backgrounds on inner editor wrappers; clear them so
   the Orbit stack on the parent shows through. */
.markdown-source-view.mod-cm6,
.markdown-source-view.mod-cm6 .cm-scroller,
.markdown-source-view.mod-cm6 .cm-content,
.markdown-source-view.mod-cm6 .cm-gutters,
.markdown-source-view.mod-cm6 .cm-line,
.markdown-preview-view .markdown-preview-sizer,
.markdown-preview-view .markdown-preview-section {
  background: transparent !important;
}

/* ============================================================
   Starfield + nebula drift — dark mode only.
   A ::before pseudo on the note view paints ~50 hand-placed
   stars (CSS themes can't run JS, so we bake positions in) plus
   two slow-drifting nebula blobs. Sits behind the text via
   z-index. Collective opacity twinkle on the whole layer.
   ============================================================ */

.theme-dark .markdown-source-view.mod-cm6 .cm-editor,
.theme-dark .markdown-preview-view {
  position: relative;
  isolation: isolate;
}

.theme-dark .markdown-source-view.mod-cm6 .cm-editor::before,
.theme-dark .markdown-preview-view::before {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
  background-image:
    /* nebula drift blobs */
    radial-gradient(ellipse 60% 45% at 88% 8%,  rgba(168, 134, 247, 0.20), transparent 70%),
    radial-gradient(ellipse 55% 50% at 10% 92%, rgba(6, 182, 212, 0.16),   transparent 70%),
    /* milky diagonal band */
    linear-gradient(115deg, transparent 24%, rgba(229, 237, 255, 0.11) 50%, transparent 76%),
    /* signature stars — brighter, with diffraction halos */
    radial-gradient(2.5px 2.5px at 12% 18%, rgba(255,255,255,1),    rgba(255,255,255,0.4) 25%, transparent 60%),
    radial-gradient(2.2px 2.2px at 78% 12%, rgba(225,235,255,0.95), rgba(225,235,255,0.3) 30%, transparent 60%),
    radial-gradient(2.4px 2.4px at 42% 64%, rgba(255,255,255,0.95), rgba(255,255,255,0.35) 28%, transparent 60%),
    radial-gradient(2.2px 2.2px at 91% 73%, rgba(225,235,255,0.9),  rgba(225,235,255,0.3) 30%, transparent 60%),
    radial-gradient(2.3px 2.3px at 24% 88%, rgba(255,255,255,0.95), rgba(255,255,255,0.3) 28%, transparent 60%),
    /* dim stars */
    radial-gradient(1.4px 1.4px at  4%  6%, rgba(210,225,255,0.85), transparent 55%),
    radial-gradient(1.2px 1.2px at 19% 32%, rgba(210,225,255,0.75), transparent 55%),
    radial-gradient(1.4px 1.4px at 33% 11%, rgba(210,225,255,0.85), transparent 55%),
    radial-gradient(1.2px 1.2px at 47% 27%, rgba(210,225,255,0.65), transparent 55%),
    radial-gradient(1.4px 1.4px at 58%  8%, rgba(210,225,255,0.85), transparent 55%),
    radial-gradient(1.2px 1.2px at 64% 38%, rgba(210,225,255,0.7),  transparent 55%),
    radial-gradient(1.3px 1.3px at 71% 22%, rgba(210,225,255,0.8),  transparent 55%),
    radial-gradient(1.2px 1.2px at 84% 41%, rgba(210,225,255,0.7),  transparent 55%),
    radial-gradient(1.4px 1.4px at 96% 28%, rgba(210,225,255,0.85), transparent 55%),
    radial-gradient(1.2px 1.2px at  8% 47%, rgba(210,225,255,0.75), transparent 55%),
    radial-gradient(1.4px 1.4px at 22% 58%, rgba(210,225,255,0.85), transparent 55%),
    radial-gradient(1.2px 1.2px at 36% 49%, rgba(210,225,255,0.7),  transparent 55%),
    radial-gradient(1.3px 1.3px at 51% 71%, rgba(210,225,255,0.8),  transparent 55%),
    radial-gradient(1.2px 1.2px at 67% 53%, rgba(210,225,255,0.75), transparent 55%),
    radial-gradient(1.2px 1.2px at 76% 67%, rgba(210,225,255,0.7),  transparent 55%),
    radial-gradient(1.4px 1.4px at 88% 59%, rgba(210,225,255,0.85), transparent 55%),
    radial-gradient(1.2px 1.2px at  3% 76%, rgba(210,225,255,0.75), transparent 55%),
    radial-gradient(1.2px 1.2px at 14% 81%, rgba(210,225,255,0.7),  transparent 55%),
    radial-gradient(1.3px 1.3px at 31% 95%, rgba(210,225,255,0.8),  transparent 55%),
    radial-gradient(1.2px 1.2px at 44% 83%, rgba(210,225,255,0.7),  transparent 55%),
    radial-gradient(1.4px 1.4px at 56% 92%, rgba(210,225,255,0.85), transparent 55%),
    radial-gradient(1.2px 1.2px at 73% 87%, rgba(210,225,255,0.75), transparent 55%),
    radial-gradient(1.2px 1.2px at 82% 96%, rgba(210,225,255,0.7),  transparent 55%),
    radial-gradient(1.3px 1.3px at 94% 84%, rgba(210,225,255,0.8),  transparent 55%),
    /* extra fill — middle/lower band, mix of warm and cool dim stars */
    radial-gradient(1.2px 1.2px at 11% 64%, rgba(255,235,210,0.6), transparent 55%),
    radial-gradient(1.4px 1.4px at 27% 75%, rgba(210,225,255,0.8), transparent 55%),
    radial-gradient(1.2px 1.2px at 39% 41%, rgba(255,235,210,0.55), transparent 55%),
    radial-gradient(1.3px 1.3px at 53% 56%, rgba(210,225,255,0.75), transparent 55%),
    radial-gradient(1.2px 1.2px at 62% 78%, rgba(210,225,255,0.7), transparent 55%),
    radial-gradient(1.4px 1.4px at 69% 44%, rgba(255,235,210,0.7), transparent 55%),
    radial-gradient(1.2px 1.2px at 81% 51%, rgba(210,225,255,0.7), transparent 55%),
    radial-gradient(1.3px 1.3px at 17% 36%, rgba(210,225,255,0.75), transparent 55%),
    radial-gradient(1.2px 1.2px at 49% 89%, rgba(255,235,210,0.6), transparent 55%),
    radial-gradient(1.2px 1.2px at 86% 78%, rgba(210,225,255,0.7), transparent 55%);
  background-repeat: no-repeat;
  animation: starscape-twinkle 8s ease-in-out infinite;
}

/* Make sure text and gutters render above the starfield layer. */
.theme-dark .markdown-source-view.mod-cm6 .cm-scroller,
.theme-dark .markdown-source-view.mod-cm6 .cm-content,
.theme-dark .markdown-source-view.mod-cm6 .cm-gutters,
.theme-dark .markdown-preview-view .markdown-preview-sizer {
  position: relative;
  z-index: 1;
}

@keyframes starscape-twinkle {
  0%, 100% { opacity: 0.78; }
  50%      { opacity: 1; }
}

@media (prefers-reduced-motion: reduce) {
  .theme-dark .markdown-source-view.mod-cm6 .cm-editor::before,
  .theme-dark .markdown-preview-view::before {
    animation: none;
  }
}
